<section id="<%= dom_id(group_deal, :participants) %>" class="card">
  <h3>Participants</h3>
  <ul class="participants">
    <% group_deal.group_participants.includes(:user).order(:joined_at).each do |participant| %>
      <li>
        <strong><%= participant.user.email %></strong>
        <span class="meta">Joined <%= time_ago_in_words(participant.joined_at) %> ago</span>
      </li>
    <% end %>
  </ul>
</section>
