<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Kykapu New" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Kykapu New">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="topbar">
      <div class="topbar__brand">
        <%= link_to "Kykapu Group Buy", root_path(as_user_id: current_user.id), class: "brand-link" %>
      </div>
      <div class="topbar__user">
        <span class="user-pill">You: <%= current_user.email %></span>
        <% if available_users.any? %>
          <div class="user-switcher">
            <% available_users.each do |user| %>
              <%= link_to user.email, request.query_parameters.merge(as_user_id: user.id), class: "user-switcher__link #{'is-active' if user.id == current_user.id}" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </header>

    <% if flash[:notice].present? || flash[:alert].present? %>
      <div class="flash-wrap">
        <% if flash[:notice].present? %>
          <p class="flash flash--notice"><%= flash[:notice] %></p>
        <% end %>
        <% if flash[:alert].present? %>
          <p class="flash flash--alert"><%= flash[:alert] %></p>
        <% end %>
      </div>
    <% end %>

    <main class="page">
      <%= yield %>
    </main>
  </body>
</html>
